# Aletheia — Environment Variables
# Copy to .env and fill in real values.

# Notion internal integration token.
# Workers use NOTION_API_TOKEN; older local scripts also accept NOTION_API_KEY.
NOTION_API_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion workspace identifier
NOTION_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Page ID of "Aletheia Memory" parent page where all 7 databases will be created
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API key — needed for Truth Diff + Trial Mode
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub webhook signature secret for the githubPrMerged Worker webhook
GITHUB_WEBHOOK_SECRET=change-me

# Notion database IDs — populated by scripts/setup-notion.ts
NOTION_DB_RAW_SIGNALS=
NOTION_DB_CONCEPTS=
NOTION_DB_COMPANY_CLAIMS=
NOTION_DB_TRUTH_DIFFS=
NOTION_DB_EVIDENCE_RECEIPTS=
NOTION_DB_APPROVALS=
NOTION_DB_TRUTH_BRIEFS=
NOTION_SEED_CLAIM_ID=

# Worker env equivalents. `ntn workers env` rejects custom names starting with NOTION_.
ALETHEIA_DB_RAW_SIGNALS=
ALETHEIA_DB_CONCEPTS=
ALETHEIA_DB_COMPANY_CLAIMS=
ALETHEIA_DB_TRUTH_DIFFS=
ALETHEIA_DB_EVIDENCE_RECEIPTS=
ALETHEIA_DB_APPROVALS=
ALETHEIA_DB_TRUTH_BRIEFS=
ALETHEIA_SEED_CLAIM_ID=

# Optional — add only after Phase B6 is stable
ELEVENLABS_API_KEY=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
